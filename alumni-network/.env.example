# Backend
NODE_ENV=development
PORT=5000
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=secret
MONGO_URI=mongodb://admin:secret@mongo:27017/alumni_db?authSource=admin
JWT_SECRET=supersecretjwtkey_change_this_in_production_minimum_32_chars
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000
MAX_FILE_SIZE=5242880

# Frontend
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_SOCKET_URL=http://localhost:5000

# Docker Hub (for CI/CD)
DOCKER_HUB_USERNAME=your_dockerhub_username
DOCKER_IMAGE_NAME=alumni-network
